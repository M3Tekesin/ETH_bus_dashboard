# Copy to .env and fill in. .env is gitignored — never commit real secrets.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/telemetry

# Authentication
AUTH_USERNAME=admin
# Argon2id hash of the password. Generate with:
#   uv run python -m app.hash_password "your password"
AUTH_PASSWORD_HASH=
# Plaintext password — only needed by scripts/load_samples.py to log in.
AUTH_PASSWORD=
# Secret used to sign JWTs (HMAC-SHA256). Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_TTL_HOURS=12
